rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidRoom(data) {
      return data.code is string && data.code.matches('^[0-9]{4}$') &&
             data.players is list && data.players.size() <= 2 &&
             data.status in ['waiting', 'playing', 'finished'];
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isValidRoom(incoming());
      allow update: if (
        // Allow joining
        (existing().status == 'waiting' && incoming().players.size() == 2 && incoming().players[0] == existing().players[0]) ||
        // Allow game moves
        (incoming().players == existing().players)
      );
      allow delete: if false;
    }
  }
}
